# saas-app — Production template
# Copy to .env.prod and fill in secrets
# SSH/runtime auto-inferred by smart defaults (ssh_host → podman, quadlet)
DOMAIN=app.example.com
APP_NAME=saas-app
VERSION=0.1.0
PORT_WEB=8000
PORT_API=8080
DATABASE_URL=postgresql://user:pass@prod-db/db
REGISTRY=ghcr.io/myorg
TAG=latest
