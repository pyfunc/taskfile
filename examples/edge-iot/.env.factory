# ─── edge-iot — FACTORY GATEWAYS ───────────────────
# Shared by gw-factory-1 and gw-factory-2
# Variables from hosts: extra keys are auto-injected (GATEWAY_ID, GATEWAY_TYPE, etc.)
APP_NAME=iot-gateway
VERSION=0.1.0
GATEWAY_TYPE=industrial
SENSOR_PROTOCOL=modbus
MQTT_BROKER=mqtt.example.com
MQTT_PORT=1883
LOG_LEVEL=info
FIRMWARE_CHANNEL=stable
