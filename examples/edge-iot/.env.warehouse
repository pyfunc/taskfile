# ─── edge-iot — WAREHOUSE GATEWAYS ─────────────────
# Shared by gw-warehouse-1 and gw-warehouse-2
# Variables from hosts: extra keys are auto-injected (GATEWAY_ID, GATEWAY_TYPE, etc.)
APP_NAME=iot-gateway
VERSION=0.1.0
GATEWAY_TYPE=storage
SENSOR_PROTOCOL=mqtt
MQTT_BROKER=mqtt.example.com
MQTT_PORT=1883
LOG_LEVEL=info
FIRMWARE_CHANNEL=stable
