# ─── mega-saas — LOCAL DEVELOPMENT ──────────────────
# Smart defaults: no ssh_host → docker/compose, env_file → .env.local
APP_NAME=mega-saas
VERSION=0.1.0
DOMAIN=localhost
LOG_LEVEL=debug
REDIS_URL=redis://localhost:6379
DB_NAME=mega_saas
DATABASE_URL=postgresql://user:pass@localhost/mega_saas
REGISTRY=ghcr.io/myorg
TAG=dev
REPLICAS=1
