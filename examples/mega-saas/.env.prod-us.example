# mega-saas — Production US template
# Copy to .env.prod-us and fill in secrets
# Smart defaults: ssh_host → podman/quadlet, env_file → .env.prod-us
APP_NAME=mega-saas
VERSION=0.1.0
DOMAIN=us.mega-saas.example.com
AWS_REGION=us-east-1
LOG_LEVEL=warn
REDIS_URL=redis://redis:6379
DB_NAME=mega_saas
DATABASE_URL=postgresql://deploy:CHANGE_ME@db/mega_saas
REGISTRY=ghcr.io/myorg
TAG=latest
REPLICAS=4
SLACK_WEBHOOK=
SENTRY_DSN=
