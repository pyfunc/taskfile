# mega-saas-v2 — Production EU template
# Copy to .env.prod-eu and fill in secrets
# hosts: prod-eu → auto: podman/quadlet, env_file defaults to .env.prod (from _defaults)
APP_NAME=mega-saas
VERSION=0.1.0
DOMAIN=eu.mega-saas.example.com
AWS_REGION=eu-west-1
LOG_LEVEL=warn
REDIS_URL=redis://redis:6379
DB_NAME=mega_saas
DATABASE_URL=postgresql://deploy:CHANGE_ME@db/mega_saas
REGISTRY=ghcr.io/myorg
TAG=latest
REPLICAS=4
SLACK_WEBHOOK=
SENTRY_DSN=
