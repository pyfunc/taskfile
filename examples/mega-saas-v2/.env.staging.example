# mega-saas-v2 — Staging template
# Copy to .env.staging and adjust values
# hosts: staging → ssh_host auto-configured, env_file: .env.staging
APP_NAME=mega-saas
VERSION=0.1.0
DOMAIN=staging.mega-saas.example.com
LOG_LEVEL=info
REDIS_URL=redis://redis:6379
DB_NAME=mega_saas
DATABASE_URL=postgresql://deploy:CHANGE_ME@db/mega_saas
REGISTRY=ghcr.io/myorg
TAG=latest
REPLICAS=1
