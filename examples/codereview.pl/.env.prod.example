# codereview.pl — Production template
# Copy to .env.prod and fill in secrets
# Smart defaults: ssh_host → podman/quadlet/~/.ssh/id_ed25519, env_file → .env.prod

# Domain
DOMAIN=codereview.pl
ENTRYPOINT=web
TLS_ENABLED=true
CERT_RESOLVER=letsencrypt

# App
NODE_ENV=production
TAG=latest
REGISTRY=ghcr.io/softreck

# Traefik
TRAEFIK_DASHBOARD=false
TRAEFIK_MEMORY=32m

# Database
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Resources (tight for VPS)
APP_MEMORY=128m
APP_CPUS=0.5
API_MEMORY=128m
API_CPUS=0.5
DB_MEMORY=128m
REDIS_MEMORY=32m
REDIS_MAXMEM=24mb

# Paths
UPLOADS_PATH=/data/uploads
