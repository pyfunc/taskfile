# cloud-aws — Generic production template
# Use .env.prod-eu or .env.prod-us for region-specific config
# Smart defaults: env_file → .env.{env_name} (auto-inferred)
APP_NAME=cloud-app
VERSION=0.1.0
DOMAIN=app.example.com
AWS_REGION=eu-west-1
AWS_PROFILE=prod
ECS_DESIRED_COUNT=4
LAMBDA_MEMORY=1024
TAG=latest
